  "Talent": {
    "1": {
      "Level": 1,
      "Name": "フォーメーション練習中",
      "Desc": "親衛隊のイノシシが<color=#ffffff>『イノシシ親衛隊：回転打法！』</color>を発動した時、ルーシーのエネルギーを2Pt回復する、15秒に1回のみ発動可能。クールタイムは親衛隊の各イノシシごとに計算される。",
      "Desc2": "「ヘルバ、右向け右！…そっちは左ですわ！このトンコツ！！！」\n鶴の一声、左右は二択、悲鳴が三声、四方にこだます。"
    },
    "2": {
      "Level": 2,
      "Name": "イノシシ大隊長",
      "Desc": "ルーシーが<color=#ffffff>『連携スキル』</color>または<color=#ffffff>『終結スキル』</color>を発動した時、味方のエージェント、ボンプおよび親衛隊のイノシシを<color=#ffffff>「かっとばせ！」</color>状態にする、継続時間10秒。",
      "Desc2": "「ルーシー隊長は紛れもなく、カリュドーンのイノシシたちにとって最高の指導者でやんす！」\n—アルボルによる、「カリュドーンの子 年間業務報告」の締めくくり。"
    },
    "3": {
      "Level": 3,
      "Name": "鉄腕の世話係",
      "Desc": "<color=#ffffff>『通常攻撃』</color>、<color=#ffffff>『回避』</color>、<color=#ffffff>『支援スキル』</color>、<color=#ffffff>『特殊スキル』</color>、<color=#ffffff>『連携スキル』</color>のスキルレベル+2",
      "Desc2": "「おれらをかっとばす時はもっと手加減してくれると、なお最高でやんす！」\n—アルボルが言わずにそっと心にしまった、締めくくりの後半部分"
    },
    "4": {
      "Level": 4,
      "Name": "無法試合",
      "Desc": "<color=#ffffff>「かっとばせ！」</color>状態にある味方の会心ダメージが追加で10%アップする。",
      "Desc2": "ルールか、審判の肋骨か——\nこの戦い、必ずどちらかが折れる。"
    },
    "5": {
      "Level": 5,
      "Name": "荒野のプリンセス",
      "Desc": "<color=#ffffff>『通常攻撃』</color>、<color=#ffffff>『回避』</color>、<color=#ffffff>『支援スキル』</color>、<color=#ffffff>『特殊スキル』</color>、<color=#ffffff>『連携スキル』</color>のスキルレベル+2",
      "Desc2": "バットの下敷きとなった者にも敬意を忘れず、\n這いつくばる敵にも詫びを入れよ。\nこれぞ、令嬢の完璧な作法なり。"
    },
    "6": {
      "Level": 6,
      "Name": "牙は烈火にも勝る",
      "Desc": "<color=#ffffff>「かっとばせ！」</color>状態の味方の<color=#ffffff>『強化特殊スキル』</color>が敵に命中すると、親衛隊のイノシシが1匹空中から落下して爆発を起こし、親衛隊のイノシシの攻撃力300%分の<color=#ff5521>炎属性ダメージ</color>を与える。それと同時に、チーム全体の<color=#ffffff>「かっとばせ！」</color>状態の継続時間が5秒延長される。延長可能回数は最大で3回、継続時間は最大30秒。<color=#ffffff>「かっとばせ！」</color>状態を重複して獲得すると、継続時間の延長可能回数がリセットされる。親衛隊のイノシシが着地して爆発を起こした後、さらに<color=#ffffff>『イノシシ親衛隊：回転打法！』</color>を一回発動する。",
      "Desc2": "通称「赤鬣親衛隊」と呼ばれるイノシシたちは、常に最前線に立つ！\nバットでぶっ飛ばされる彼らの心境は、本望か無念か。\n知る由もないが——勇敢なイノシシたちよ、一番乗りは任せた！"
    }
  }
}