  "Talent": {
    "1": {
      "Level": 1,
      "Name": "悠闲一刻",
      "Desc": "派派在<color=#ffffff>[特殊技：轮胎转]</color>、<color=#ffffff>[强化特殊技：引擎转]</color>或<color=#ffffff>[终结技]</color>中发动旋转斩击命中敌人时，有50%概率额外获得1层<color=#ffffff>[动力]</color>，<color=#ffffff>[动力]</color>的叠加层数上限提升至30层。",
      "Desc2": "卡吕冬之子某个平常的上午，派派慢悠悠地打了个哈欠。\n「早上好——」\n「今天也能悠闲地度过吧？养生可是很重要的，不然这个人会过劳死哦——」"
    },
    "2": {
      "Level": 2,
      "Name": "上进心",
      "Desc": "在<color=#ffffff>[特殊技：轮胎转]</color>和<color=#ffffff>[强化特殊技：引擎转]</color>发动期间，派派的移动速度有所提升；在<color=#ffffff>[特殊技：有亿点重]</color>、<color=#ffffff>[强化特殊技：非常重]</color>和<color=#ffffff>[终结技]</color>中发动下砸攻击命中敌人时，招式造成的<color=#f0d12b>物理伤害</color>提升10%，每拥有1层<color=#ffffff>[动力]</color>，该增益效果额外提升1%。",
      "Desc2": "暂时的努力，是为了更加长久的休憩。\n当然，如果能一直都不努力就更好了——派派伸了个懒腰，拍了拍卡车里的柔软床铺，躺了下来。"
    },
    "3": {
      "Level": 3,
      "Name": "卡车专家",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "派派总是对卡车的一切充满兴趣。\n即使是在熟睡的状态下，只要引擎声响起，少女就能瞬间清醒：\n「100马力，载重5吨，这是…三门重工新发售的轻型卡车！」"
    },
    "4": {
      "Level": 4,
      "Name": "技巧娴熟",
      "Desc": "队伍中任意角色对敌人施加属性异常效果时，派派回复20点能量，30秒内最多触发一次。",
      "Desc2": "成为派派的乘客是一件让人心惊胆战的事。\n通常在她慢悠悠地提醒「坐~稳~咯~」的时候，「稳」字发音还没结束，卡车就已经向前行驶了惊人的距离。\n当然，她总能在最短的时间内把你安全送到目的地——精神损失不算在内。"
    },
    "5": {
      "Level": 5,
      "Name": "私人爱好",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "派派似乎拥有一些不太符合外表的私人爱好。\n「这匹马好像很能跑的样子…唔，但是买的人好少，果然还是那匹胜率更高吗…」\n「嗝——燃油饮…我才没喝多…再来一杯！」"
    },
    "6": {
      "Level": 6,
      "Name": "轻度兴奋",
      "Desc": "<color=#ffffff>[强化特殊技：引擎转]</color>的持续时间上限提升2秒，<color=#ffffff>[动力]</color>的持续时间提升4秒。",
      "Desc2": "如你所知，派派最大的愿望是永远都能悠闲度日。\n但此刻，少女总是半睁着的双眸竟少有的精神奕奕。\n「如果是为了你…这个人稍微努力一下下，也可以哦~」"
    }
  }
}