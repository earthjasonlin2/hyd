  "Talent": {
    "1": {
      "Level": 1,
      "Name": "满月蓄势",
      "Desc": "<color=#ffffff>[强化特殊技]</color>命中敌人时，招式造成的失衡值提升12%，8秒内最多触发一次；在<color=#ffffff>[强化特殊技]</color>中完成蓄力时，该增益效果额外提升10%。",
      "Desc2": "据记载，当狼人身处月夜的时候，其攻击性将有显著提升。\n「不要直视月亮。」"
    },
    "2": {
      "Level": 2,
      "Name": "能量回馈",
      "Desc": "使敌人失衡或触发队友的<color=#ffffff>[连携技]</color>时，莱卡恩回复5点能量，1秒内最多触发一次。",
      "Desc2": "「对于犬科动物来说，当他们完成某些较难的任务后，大脑所产生的兴奋感会短暂地提升他们的精神能量。」\n「这时作为主人的你若是可以摸摸他们的头，以示鼓励，他们将为此感到非常开心…」\n——摘自《犬类动物不靠谱研究手册》"
    },
    "3": {
      "Level": 3,
      "Name": "执事教养",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "他的举手投足总是充满从容，他的言谈举止让人如沐春风。执事的教养就是让一切都在掌握中。"
    },
    "4": {
      "Level": 4,
      "Name": "保持风度",
      "Desc": "在<color=#ffffff>[普通攻击]</color>或<color=#ffffff>[特殊技]</color>的发动期间受到敌方攻击时，\n莱卡恩立刻获得等同于自身7.5%生命值上限的护盾，持续15秒，\n护盾持续期间抗打断等级提升，15秒内最多触发一次。",
      "Desc2": "「优秀的执事，在任何情况下都能保持风度。」"
    },
    "5": {
      "Level": 5,
      "Name": "头狼本色",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "他的眼神暗藏野性，他的喉间滚动嚎音。不论现在的他如何优雅，礼服下的他依然凶猛。"
    },
    "6": {
      "Level": 6,
      "Name": "冷酷猎手",
      "Desc": "蓄力攻击命中敌人时，莱卡恩对目标造成的伤害提升10%，最多叠加5层，持续12秒；同一招式内最多叠加1层效果，重复触发时刷新持续时间。",
      "Desc2": "「抱歉，即使如此，我也是不会手下留情的。」\n「毕竟，空洞可不是什么需要公平对决的地方。」"
    }
  }
}