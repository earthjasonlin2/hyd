  "Talent": {
    "1": {
      "Level": 1,
      "Name": "队形操练中",
      "Desc": "亲卫队小猪发动<color=#ffffff>[亲卫队小猪：回旋挥击！]</color>时，为露西回复2点能量，15秒内最多触发一次，每只亲卫队小猪单独结算冷却时间。",
      "Desc2": "「阿草，向右看齐！…那是左边，笨蛋！！！」\n一声令下，两种方向，三阵惨呼，四面哀嚎。"
    },
    "2": {
      "Level": 2,
      "Name": "小猪大队长",
      "Desc": "露西发动<color=#ffffff>[连携技]</color>或<color=#ffffff>[终结技]</color>时，将为所有友方角色、邦布和亲卫队小猪施加<color=#ffffff>[加油！]</color>状态，持续10秒。",
      "Desc2": "「毋庸置疑，露西队长是卡吕冬野猪希人最棒的领导者！」\n这是阿木在「卡吕冬之子年度工作报告」中的结语。"
    },
    "3": {
      "Level": 3,
      "Name": "铁腕监护人",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "「要是露西队长在打飞我们的时候下手轻点就更好了。」\n这是阿木没敢说出来的后半句心里话。"
    },
    "4": {
      "Level": 4,
      "Name": "无规则球赛",
      "Desc": "处于<color=#ffffff>[加油！]</color>状态下的友方单位，暴击伤害额外提升10%。",
      "Desc2": "规则和裁判的肋骨，总有一样要被打破。"
    },
    "5": {
      "Level": 5,
      "Name": "荒原贵公主",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "对球棍下惨叫的对手用敬语，\n向匍匐在脚边的敌人说抱歉，\n这就是千金的完美礼仪。"
    },
    "6": {
      "Level": 6,
      "Name": "獠牙堪烈火",
      "Desc": "处于<color=#ffffff>[加油！]</color>状态下的队友发动<color=#ffffff>[强化特殊技]</color>命中敌人时，一只亲卫队小猪会从空中落地引发爆炸，造成等同于亲卫队小猪300%攻击力的<color=#ff5521>火属性伤害</color>，并使全队<color=#ffffff>[加油！]</color>状态的持续时间提升5秒；持续时间最多提升3次，上限30秒，重新获得<color=#ffffff>[加油！]</color>状态时刷新可提升次数；亲卫队小猪落地引发爆炸后，将会发动一次<color=#ffffff>[亲卫队小猪：回旋挥击！]</color>。",
      "Desc2": "被称为「赤鬣亲卫队」的小猪希人们总是冲锋在战斗的最前线！\n虽然说不清从球棒起飞的那一刹那，心绪是万念俱灰还是心甘情愿。\n勇敢小猪，身先士卒！"
    }
