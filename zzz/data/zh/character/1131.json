  "Talent": {
    "1": {
      "Level": 1,
      "Name": "振奋汇流",
      "Desc": "苍角触发<color=#ffffff>[核心被动：刃旗助威]</color>或<color=#ffffff>[额外能力：团膳套餐]</color>时，增益效果的持续时间提升8秒。",
      "Desc2": "蓄能完毕后，特制充能模块可以形成以太能量风场，为周围的以太设备充能。\n对苍角来说，这就像她最喜欢的聚餐时刻。\n「大家~来吃自助餐咯！」"
    },
    "2": {
      "Level": 2,
      "Name": "实验型充能模块",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[冲刺攻击]</color>、<color=#ffffff>[闪避反击]</color>、<color=#ffffff>[快速支援]</color>命中敌人时，苍角有15%的概率获得一层<color=#ffffff>[涡流]</color>，1秒内最多触发一次；<color=#ffffff>[涡流]</color>层数到达上限后，若再次获得<color=#ffffff>[涡流]</color>，将改为苍角回复1.2点能量。",
      "Desc2": "充能模块能够在战斗中不断积蓄能量，\n因此被研发部门视作划时代的新概念战术兵器。\n但对苍角来说，蓄能完毕，只意味着开饭的时间到了。"
    },
    "3": {
      "Level": 3,
      "Name": "出勤餐补",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "要激励苍角努力锻炼的方法非常简单：提高出勤的餐饮补助标准就行。"
    },
    "4": {
      "Level": 4,
      "Name": "失温症",
      "Desc": "<color=#ffffff>[展旗]</color>攻击命中敌人时，目标的<color=#98eff0>冰属性伤害抗性</color>降低10%，持续8秒。",
      "Desc2": "特制武装战鬼刃旗内置强大的制冷装置，产生冷气的催化剂中含有以太物质，能深度伤害被击中的敌人。"
    },
    "5": {
      "Level": 5,
      "Name": "夜宵福利",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "要进一步激励苍角努力锻炼的方法也很简单：在出勤餐补之外再追加夜宵。"
    },
    "6": {
      "Level": 6,
      "Name": "朔风侵袭",
      "Desc": "<color=#ffffff>[霜染刃旗]</color>状态下，强化<color=#ffffff>[普通攻击]</color>和强化<color=#ffffff>[冲刺攻击]</color>的可发动次数提升至12次，且招式造成的伤害提升45%。",
      "Desc2": "解开刃旗内的保险装置，让武器以最大功率模式运转，不仅战斗没问题…用来吹凉便当也没问题。"
    }
  }
}