  "Talent": {
    "1": {
      "Level": 1,
      "Name": "英雄主义",
      "Desc": "<color=#ffffff>[匪石之盾]</color>提供的护盾及其上限提升30%，<color=#ffffff>[匪石之盾]</color>失效时，<color=#ffffff>[核心被动：守望者]</color>提供的异常精通提升效果额外维持10秒。",
      "Desc2": "团队行动的时候，赛斯永远是冲在最前面的人。\n「逮捕犯人就交给我吧！我的近身擒拿成绩是99分，扣掉的那一分是因为不小心扭伤了教官的手腕。」"
    },
    "2": {
      "Level": 2,
      "Name": "年少轻狂",
      "Desc": "进入战场时，赛斯立刻为自身累积75%<color=#ffffff>[意气]</color>；发动<color=#ffffff>[普通攻击：雷霆击-感电]</color>命中敌人时，招式累积的<color=#2eb6ff>电属性异常积蓄值</color>提升35%。",
      "Desc2": "赛斯很容易被各种犯罪者小看。\n或许是因为他的眼神太过清澈，又或许是因为那无害的毛茸茸耳朵和尾巴——\n无论如何，所有看低他的人，最终都会付出相应的代价。"
    },
    "3": {
      "Level": 3,
      "Name": "钝感力",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "「像你这么厉害的治安官，肯定做什么都是靠自己吧？绝对没依赖其他人吧？」\n即使被这么说了，赛斯依然不动声色。\n直到半夜，他才忽然惊醒：\n「那家伙白天的话…莫非是在讽刺我？」"
    },
    "4": {
      "Level": 4,
      "Name": "初心",
      "Desc": "<color=#ffffff>[招架支援：迅雷盾]</color>造成的失衡值提升25%。",
      "Desc2": "「放下你那愚蠢的善恶观。世上没有一种方式可以守护所有人。有时候，你必须做出选择。」\n「这就是我的选择，也是治安官最基本的职责——是你变了，哥哥。」"
    },
    "5": {
      "Level": 5,
      "Name": "憧憬的距离",
      "Desc": "<color=#ffffff>[普通攻击]</color>、<color=#ffffff>[闪避]</color>、<color=#ffffff>[支援技]</color>、<color=#ffffff>[特殊技]</color>、<color=#ffffff>[连携技]</color> 技能等级+2",
      "Desc2": "对于自己的兄长，赛斯曾抱有极度的憧憬和尊敬。\n但就像你知道的那样——「憧憬」是距离「理解」最遥远的距离。\n「总有一天，我会成为最厉害的治安官…让那家伙收回之前的话！」"
    },
    "6": {
      "Level": 6,
      "Name": "理想主义",
      "Desc": "赛斯在<color=#ffffff>[普通攻击：雷霆击-感电]</color>中发动终结一击命中敌人时，额外造成自身500%攻击力的伤害，本次攻击必定触发暴击，且暴击伤害提升60%。",
      "Desc2": "少年人眼里的一切很清晰，黑白分明，善恶有别。\n一定会有人想告诉他世界的颜色是混沌的灰。但黑白分明善恶有别的世界…不值得追求吗？"
    }
  }
}