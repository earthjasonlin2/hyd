            "Messages": {
                "131140001": {
                    "Id": 131140001,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "階差宇宙のテストの進捗はどうだ？人間喜劇…予想外だな。スクリューガムは他の天才たちとは違い君主の特性を持っている。だからこそ彼は他人の意見を受け入れやすいのだろう。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140002
                    ],
                    "Sender": "NPC"
                },
                "131140002": {
                    "Id": 131140002,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "暇な時に今回の階差宇宙アップデートのサンプルとして新しい資料を整理しておいた。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140003
                    ],
                    "Sender": "NPC"
                },
                "131140003": {
                    "Id": 131140003,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "君にもデータを送ろう。テスト前の予習だと思って受け取ってくれ。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140004
                    ],
                    "Sender": "NPC"
                },
                "131140004": {
                    "Id": 131140004,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "添付ファイル『銀河系知的生命体のライフサイクルに関する調査<unbreak>-2157</unbreak>紀』を送信しました。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140005,
                        131140006,
                        131140009
                    ],
                    "Sender": "System"
                },
                "131140005": {
                    "Id": 131140005,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "{F#私}{M#俺} はただのテスターだから、頭を使うのは仕事じゃない{F#よ}{M#ぞ}。",
                    "OptionText": "{F#私}{M#俺} はただのテスターだよ。",
                    "NextItemIDList": [
                        131140011
                    ],
                    "Sender": "Player"
                },
                "131140006": {
                    "Id": 131140006,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "今から読む。{F#私}{M#俺} は勉強熱心だから{F#ね}{M#な} 。",
                    "OptionText": "今から読む。",
                    "NextItemIDList": [
                        131140007
                    ],
                    "Sender": "Player"
                },
                "131140009": {
                    "Id": 131140009,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "誰だよ？{F#あんた}{M#お前}のことなんか知らない。",
                    "OptionText": "誰だよ？",
                    "NextItemIDList": [
                        131140010
                    ],
                    "Sender": "Player"
                },
                "131140011": {
                    "Id": 131140011,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "方程式によって異なる人生を体験することができる。しかし、それは自分ではない他の誰かになるためではなく、自分がどこに向かうのかを考えるための体験だ。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140012
                    ],
                    "Sender": "NPC"
                },
                "131140007": {
                    "Id": 131140007,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "ちなみに、これを全部読み終わるまでどれくらいの時間がかかる{F#の}{M#んだ}？",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140008
                    ],
                    "Sender": "PlayerAuto"
                },
                "131140010": {
                    "Id": 131140010,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "僕のことを知っているかどうかは重要ではない。重要なのは己を知ることと僕が送った資料を読むことだ。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140011
                    ],
                    "Sender": "NPC"
                },
                "131140012": {
                    "Id": 131140012,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "天才の研究が君とは関係ないとしても、君が「人生」の課題について考えるのをやめる理由にはならない。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140013
                    ],
                    "Sender": "NPC"
                },
                "131140008": {
                    "Id": 131140008,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "控えめに見積もって、1琥珀紀くらいあれば読めるだろう。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140011
                    ],
                    "Sender": "NPC"
                },
                "131140013": {
                    "Id": 131140013,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "安心しろ。君のような読者には、文献レビューとまとめの部分を読むだけで十分だ。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140014
                    ],
                    "Sender": "NPC"
                },
                "131140014": {
                    "Id": 131140014,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "スクリューガムであっても、この長い資料を一字一句読むことはないだろう。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140015
                    ],
                    "Sender": "NPC"
                },
                "131140015": {
                    "Id": 131140015,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "スクリューガムが言ってる「パートナー」って{F#あんた}{M#お前}のことだったの{F#}{M#か}？",
                    "OptionText": "スクリューガムに協力してるの{F#}{M#か}？",
                    "NextItemIDList": [
                        131140016
                    ],
                    "Sender": "Player"
                },
                "131140016": {
                    "Id": 131140016,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "スクリューガムは知的生命体間の違いと衝突を理解し、それを解消することを課題にしている。僕は学術交流として彼に少しの資料と助言を提供したに過ぎない。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140017
                    ],
                    "Sender": "NPC"
                },
                "131140017": {
                    "Id": 131140017,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "彼がそれを過剰に評価して、「パートナー」などと呼んだのだろう。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140018,
                        131140020
                    ],
                    "Sender": "NPC"
                },
                "131140018": {
                    "Id": 131140018,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "スクリューガムにパートナー呼ばわりされたら、",
                    "OptionText": "さすが。",
                    "NextItemIDList": [
                        131140019
                    ],
                    "Sender": "Player"
                },
                "131140020": {
                    "Id": 131140020,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "スクリューガムは{F#あんた}{M#お前}のことを高く評価してるってことだ。",
                    "OptionText": "{F#あんた}{M#お前}を高く評価してる。",
                    "NextItemIDList": [
                        131140021
                    ],
                    "Sender": "Player"
                },
                "131140019": {
                    "Id": 131140019,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "舞い上がってしまうような人をたくさん見てきた。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140022
                    ],
                    "Sender": "PlayerAuto"
                },
                "131140021": {
                    "Id": 131140021,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": null,
                    "Name": null,
                    "IconPath": null,
                    "MainText": "でも、彼の誘いを断った。どうして？",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140022
                    ],
                    "Sender": "PlayerAuto"
                },
                "131140022": {
                    "Id": 131140022,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "天才たちは恒星のような存在だ。彼らが創造したものには星系を照らすほどの価値がある。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140023
                    ],
                    "Sender": "NPC"
                },
                "131140023": {
                    "Id": 131140023,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "凡人は天才たちに付いていき、その真似をしようとするが、最後にはその光に目が眩んでしまい、前途を見失うのだ。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140024
                    ],
                    "Sender": "NPC"
                },
                "131140024": {
                    "Id": 131140024,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "彼には彼の課題があり、僕にも僕の課題がある。",
                    "OptionText": null,
                    "NextItemIDList": [
                        131140025
                    ],
                    "Sender": "NPC"
                },
                "131140025": {
                    "Id": 131140025,
                    "ItemType": "Text",
                    "ItemContentID": null,
                    "ContactsID": 1305,
                    "Name": "Dr.レイシオ",
                    "IconPath": "SpriteOutput/AvatarRoundIcon/Avatar/1305.png",
                    "MainText": "自分の道は自分の足で歩かなければならない。僕にとってもそうだし、君にとっても同じことだ。",
                    "OptionText": null,
                    "NextItemIDList": [],
                    "Sender": "NPC"
                }
            },
            "MessageStart": 131140001
        }
    ]
